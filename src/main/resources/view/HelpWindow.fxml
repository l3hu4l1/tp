<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" title="Help - VendorVault"
         type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/vendor_vault.png"/>
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
        <URL value="@DarkTheme.css"/>
        <URL value="@Extensions.css"/>
      </stylesheets>


      <VBox styleClass="background">

        <HBox fx:id="helpTitleBar" alignment="CENTER_LEFT" spacing="10"
              style="-fx-padding: 14 18 14 18; -fx-border-color: #444; -fx-border-width: 0 0 1 0;">
          <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
            <image>
              <Image url="@/images/help_icon.png"/>
            </image>
          </ImageView>
          <Label text="VendorVault — Help" styleClass="label-header"
                 style="-fx-font-size: 18pt;"/>
          <Region HBox.hgrow="ALWAYS"/>
          <Button fx:id="copyButton" mnemonicParsing="false"
                  onAction="#copyUrl" text="Copy user guide URL"
                  styleClass="button"/>
        </HBox>

      </VBox>

    </Scene>
  </scene>
</fx:root>
