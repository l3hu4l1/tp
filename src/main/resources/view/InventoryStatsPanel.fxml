<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<HBox fx:id="statsStrip"
      styleClass="stats-strip"
      alignment="CENTER_LEFT"
      spacing="10"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1">

    <stylesheets>
        <URL value="@InventoryStatsPanel.css"/>
    </stylesheets>

    <!-- LHS: two stacked stat cards -->
    <VBox fx:id="lhsCards" spacing="10" fillWidth="true" HBox.hgrow="ALWAYS">

        <!-- Active Contacts card -->
        <VBox styleClass="stat-card" maxWidth="Infinity" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Pane fx:id="contactMiniChart"
                      prefWidth="48" prefHeight="48"
                      minWidth="48" minHeight="48"
                      maxWidth="48" maxHeight="48"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="contactTitle" text="Active Contacts" styleClass="stat-card-title"/>
                    <HBox alignment="BOTTOM_LEFT" spacing="6">
                        <Label fx:id="contactValue" styleClass="stat-card-value"/>
                        <Label fx:id="contactTotal" styleClass="stat-card-total"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>

        <!-- Active Products card -->
        <VBox styleClass="stat-card" maxWidth="Infinity" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Pane fx:id="productMiniChart"
                      prefWidth="48" prefHeight="48"
                      minWidth="48" minHeight="48"
                      maxWidth="48" maxHeight="48"/>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="productTitle" text="Active Products" styleClass="stat-card-title"/>
                    <HBox alignment="BOTTOM_LEFT" spacing="6">
                        <Label fx:id="productValue" styleClass="stat-card-value"/>
                        <Label fx:id="productTotal" styleClass="stat-card-total"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

    <!-- RHS: donut chart card -->
    <VBox fx:id="donutCard" styleClass="donut-card" spacing="6" HBox.hgrow="ALWAYS">

        <Label text="Stock Status" styleClass="donut-card-title"/>

        <HBox alignment="CENTER_LEFT">

            <StackPane minWidth="130" minHeight="130" prefWidth="130" prefHeight="130">
                <PieChart fx:id="pieChart"
                          labelsVisible="false" legendVisible="false"
                          animated="false" startAngle="90" clockwise="true"
                          prefWidth="130" prefHeight="130"
                          minWidth="130" minHeight="130"
                          maxWidth="130" maxHeight="130"/>

                <!-- Donut hole (styled via CSS now) -->
                <Circle fx:id="donutHole"
                        radius="36"
                        styleClass="donut-bg"/>

                <VBox fx:id="centreBox" alignment="CENTER">
                    <Label fx:id="countLabel" styleClass="donut-centre-count"/>
                    <Label text="low stock" styleClass="donut-centre-sub"/>
                </VBox>
            </StackPane>

            <!-- Legend -->
            <VBox fx:id="legendBox" spacing="8" alignment="CENTER_LEFT">
                <padding><Insets left="12"/></padding>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Circle fx:id="dotIn"
                            radius="5"
                            styleClass="donut-in"/>
                    <Label fx:id="legendInLabel" styleClass="donut-legend-label"/>
                </HBox>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Circle fx:id="dotLow"
                            radius="5"
                            styleClass="donut-low"/>
                    <Label fx:id="legendLowLabel" styleClass="donut-legend-label"/>
                </HBox>

            </VBox>

        </HBox>
    </VBox>

</HBox>
